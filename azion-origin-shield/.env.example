# Base64 representation of username:password
AZION_BASIC_AUTH=your_base64_encoded_credentials

# Azion network list containing Origin Shield addresses
NETWORK_LIST_ID=187

# Existing BIG-IP external data group
DATA_GROUP_NAME=ext_dg_azion_origin_shield

# Local file generated for the external data group
OUTPUT_FILE=/root/ext_dg_azion_origin_shield.txt
